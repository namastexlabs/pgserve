# Dependencies
# No trailing slash — `node_modules/` matches only directories, but a
# symlink-to-node_modules slips through. Slashless form catches both.
node_modules
.pnpm-store/

# Build outputs
dist/
*.tsbuildinfo

# Test data
data/
*.db
*.db-shm
*.db-wal

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Lock files (keep in project)
.pglite-server.lock

# Environment
.env
.env.local

# Benchmark results
tests/benchmarks/results/

demo-data/
test-data-*/
*.log

# Vector benchmark fixtures (large generated files)
tests/benchmarks/fixtures/
